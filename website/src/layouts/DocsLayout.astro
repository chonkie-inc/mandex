---
import Layout from './Layout.astro';

const { frontmatter } = Astro.props;
const title = frontmatter?.title || 'Docs';
const description = frontmatter?.description || '';
const currentPath = Astro.url.pathname;

const sidebar = [
  { label: 'Overview', href: '/docs/' },
  { label: 'Getting Started', href: '/docs/getting-started/' },
  { type: 'group', label: 'Commands', items: [
    { label: 'mx pull', href: '/docs/commands/pull/' },
    { label: 'mx search', href: '/docs/commands/search/' },
    { label: 'mx sync', href: '/docs/commands/sync/' },
    { label: 'mx init', href: '/docs/commands/init/' },
    { label: 'mx show', href: '/docs/commands/show/' },
    { label: 'mx list', href: '/docs/commands/list/' },
    { label: 'mx build', href: '/docs/commands/build/' },
  ]},
  { label: 'Configuration', href: '/docs/configuration/' },
  { type: 'group', label: 'Integrations', items: [
    { label: 'Claude Code', href: '/docs/integrations/claude-code/' },
    { label: 'Cursor', href: '/docs/integrations/cursor/' },
    { label: 'Codex', href: '/docs/integrations/codex/' },
    { label: 'Windsurf', href: '/docs/integrations/windsurf/' },
    { label: 'Cline', href: '/docs/integrations/cline/' },
    { label: 'Copilot', href: '/docs/integrations/copilot/' },
    { label: 'OpenClaw', href: '/docs/integrations/openclaw/' },
    { label: 'Amp', href: '/docs/integrations/amp/' },
    { label: 'Antigravity', href: '/docs/integrations/antigravity/' },
    { label: 'Gemini', href: '/docs/integrations/gemini/' },
  ]},
  { label: 'For Package Authors', href: '/docs/for-authors/' },
];

function isActive(href: string) {
  return currentPath === href || currentPath === href.slice(0, -1);
}
---

<Layout title={`${title} — mandex docs`}>
  <div class="flex-1 flex">
    <!-- Sidebar -->
    <aside
      class="hidden md:flex shrink-0 flex-col border-r py-6 px-5 sticky top-0 overflow-y-auto"
      style="width: 240px; border-color: var(--color-border); height: 100vh;"
    >
      <a
        href="/docs/"
        class="text-[13px] font-mono font-semibold uppercase tracking-wider mb-4 block"
        style="color: var(--color-text); text-decoration: none;"
      >Docs</a>

      <nav class="flex flex-col gap-0.5">
        {sidebar.map((item) =>
          item.type === 'group' ? (
            <div class="mt-4 mb-1">
              <span
                class="text-[11px] font-mono font-semibold uppercase tracking-wider"
                style="color: var(--color-text-tertiary);"
              >{item.label}</span>
              <div class="flex flex-col gap-0.5 mt-1">
                {item.items?.map((sub) => (
                  <a
                    href={sub.href}
                    class="text-[13px] font-mono py-1 px-2 transition-colors"
                    style={isActive(sub.href)
                      ? `color: var(--color-text); background: var(--color-background-secondary); border-left: 2px solid #059669; padding-left: 6px; text-decoration: none;`
                      : `color: var(--color-text-secondary); text-decoration: none;`
                    }
                  >{sub.label}</a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="text-[13px] font-mono py-1 px-2 transition-colors"
              style={isActive(item.href)
                ? `color: var(--color-text); background: var(--color-background-secondary); border-left: 2px solid #059669; padding-left: 6px; text-decoration: none;`
                : `color: var(--color-text-secondary); text-decoration: none;`
              }
            >{item.label}</a>
          )
        )}
      </nav>
    </aside>

    <!-- Content -->
    <!-- Content + TOC -->
    <div class="flex-1 flex min-w-0">
      <!-- Main content -->
      <main class="flex-1 min-w-0 py-8 px-6 md:px-10 overflow-y-auto" id="docs-content">
        <h1
          class="text-2xl md:text-3xl font-bold tracking-tight mb-1"
          style="color: var(--color-text);"
        >{title}</h1>
        {description && (
          <p class="text-sm mb-4" style="color: var(--color-text-tertiary);">{description}</p>
        )}
        <div class="h-px mb-6" style="background: var(--color-border);"></div>
        <div class="prose">
          <slot />
        </div>
      </main>

      <!-- Right TOC -->
      <aside
        class="hidden lg:block shrink-0 py-8 pr-6 pl-5 border-l sticky top-0 overflow-y-auto"
        style="width: 200px; height: 100vh; border-color: var(--color-border);"
      >
        <div>
          <span
            class="text-[11px] font-mono font-semibold uppercase tracking-wider mb-3 block"
            style="color: var(--color-text-tertiary);"
          >On this page</span>
          <nav id="docs-toc" class="flex flex-col gap-1">
          </nav>
        </div>
      </aside>
    </div>

    <script is:inline>
      (function() {
        var content = document.getElementById('docs-content');
        var toc = document.getElementById('docs-toc');
        if (!content || !toc) return;

        var headings = content.querySelectorAll('h2, h3');
        headings.forEach(function(h) {
          var id = h.textContent.toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-');
          h.id = id;

          var a = document.createElement('a');
          a.href = '#' + id;
          a.textContent = h.textContent;
          a.style.textDecoration = 'none';
          a.style.color = 'var(--color-text-tertiary)';
          a.style.fontSize = '12px';
          a.style.fontFamily = "'Geist Mono', monospace";
          a.style.lineHeight = '1.6';
          a.style.transition = 'color 0.15s';
          if (h.tagName === 'H3') {
            a.style.paddingLeft = '10px';
          }
          a.addEventListener('mouseenter', function() { this.style.color = 'var(--color-text)'; });
          a.addEventListener('mouseleave', function() { this.style.color = 'var(--color-text-tertiary)'; });
          toc.appendChild(a);
        });

        // Scroll spy
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              toc.querySelectorAll('a').forEach(function(a) {
                a.style.color = 'var(--color-text-tertiary)';
                a.style.borderLeft = 'none';
                a.style.paddingLeft = a.dataset.indent === 'true' ? '10px' : '0';
              });
              var active = toc.querySelector('a[href="#' + entry.target.id + '"]');
              if (active) {
                active.style.color = 'var(--color-text)';
                active.style.borderLeft = '2px solid #059669';
                active.style.paddingLeft = active.dataset.indent === 'true' ? '12px' : '6px';
              }
            }
          });
        }, { rootMargin: '-80px 0px -60% 0px' });

        headings.forEach(function(h) { observer.observe(h); });

        // Mark h3 links for indent tracking
        toc.querySelectorAll('a').forEach(function(a) {
          if (a.style.paddingLeft === '10px') a.dataset.indent = 'true';
        });
        // Copy buttons on code blocks
        content.querySelectorAll('pre').forEach(function(pre) {
          var btn = document.createElement('button');
          btn.className = 'copy-btn';
          btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';
          btn.addEventListener('click', function() {
            var code = pre.querySelector('code');
            var text = code ? code.textContent : pre.textContent;
            navigator.clipboard.writeText(text).then(function() {
              btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
              setTimeout(function() {
                btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';
              }, 1500);
            });
          });
          pre.appendChild(btn);
        });
      })();
    </script>
  </div>
</Layout>
