---
import Layout from '../layouts/Layout.astro';
import { marked } from 'marked';
import rawContent from '../content/about.md?raw';

const html = await marked(rawContent);
---

<Layout title="About - mandex" description="Why documentation should be distributed like packages, not served like APIs.">
  <div class="max-w-5xl mx-auto px-6 py-16 flex gap-8 items-start">

    <!-- Sticky TOC — left of content, same width as nav icon cluster -->
    <aside id="toc-aside" class="hidden xl:block w-44 shrink-0">
      <nav id="toc" class="sticky top-20 text-xs leading-relaxed">
        <p class="font-medium mb-3 uppercase tracking-wide" style="color: var(--color-text-tertiary); font-size: 0.65rem; letter-spacing: 0.1em;">On this page</p>
        <ul id="toc-list" class="space-y-1.5"></ul>
      </nav>
    </aside>

    <!-- Article content -->
    <article class="max-w-3xl min-w-0 flex-1">
      <div class="prose-mandex" set:html={html} />
    </article>

  </div>
</Layout>

<script>
  const tocList = document.getElementById('toc-list');
  if (!tocList) throw new Error('no toc');

  // Collect all h2 and h3 from the article
  const headings = document.querySelectorAll('article h2, article h3');
  if (headings.length === 0) {
    document.getElementById('toc-aside')!.style.display = 'none';
  }

  // Give each heading an id if it doesn't have one
  headings.forEach((h) => {
    if (!h.id) {
      h.id = h.textContent!
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-|-$/g, '');
    }
  });

  // Build TOC
  headings.forEach((h) => {
    const li = document.createElement('li');
    const a = document.createElement('a');
    a.href = `#${h.id}`;
    a.textContent = h.textContent;
    a.className = 'toc-link block truncate transition-colors';
    a.style.color = 'var(--color-text-tertiary)';
    a.style.paddingLeft = h.tagName === 'H3' ? '0.75rem' : '0';

    a.addEventListener('mouseenter', () => {
      if (!a.classList.contains('toc-active')) {
        a.style.color = 'var(--color-text-secondary)';
      }
    });
    a.addEventListener('mouseleave', () => {
      if (!a.classList.contains('toc-active')) {
        a.style.color = 'var(--color-text-tertiary)';
      }
    });

    li.appendChild(a);
    tocList.appendChild(li);
  });

  // Highlight active section on scroll
  const links = tocList.querySelectorAll<HTMLAnchorElement>('.toc-link');

  function setActive(id: string) {
    links.forEach((a) => {
      const active = a.getAttribute('href') === `#${id}`;
      a.classList.toggle('toc-active', active);
      a.style.color = active ? 'var(--color-accent)' : 'var(--color-text-tertiary)';
      a.style.fontWeight = active ? '500' : '';
    });
  }

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
          break;
        }
      }
    },
    { rootMargin: '-20% 0px -70% 0px' }
  );

  headings.forEach((h) => observer.observe(h));
</script>
