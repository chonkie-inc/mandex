---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';

// Read post.md from project root
const postPath = path.resolve(process.cwd(), '../post.md');
const markdown = fs.readFileSync(postPath, 'utf-8');

// Extract h2 and h3 headings for TOC
const tocEntries: { text: string; slug: string; level: number }[] = [];
const headingRegex = /^(#{2,3})\s+(.+)$/gm;
let match;
while ((match = headingRegex.exec(markdown)) !== null) {
  const text = match[2];
  const slug = text.toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-');
  tocEntries.push({ text, slug, level: match[1].length });
}

// Custom renderer to add ids to headings
const renderer = new marked.Renderer();
renderer.heading = function({ text, depth }: { text: string; depth: number }) {
  const slug = text.toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-');
  const tag = `h${depth}`;
  return `<${tag} id="${slug}">${text}</${tag}>`;
};

const html = marked(markdown, { renderer }) as string;
---

<Layout title="mandex — About">
  <div class="flex-1">
    <!-- Back link -->
    <div class="px-5 py-2.5 border-b" style="border-color: var(--color-border);">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-[13px] font-mono transition-opacity hover:opacity-70"
        style="color: var(--color-text-secondary);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        Back
      </a>
    </div>

    <!-- Header -->
    <div class="px-5 py-5 border-b" style="border-color: var(--color-border);">
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-text-tertiary);">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
        </svg>
        <span class="text-[11px] font-mono font-medium uppercase tracking-widest" style="color: var(--color-text-tertiary);">
          About
        </span>
      </div>
    </div>

    <!-- Two-column layout -->
    <div class="flex">
      <!-- TOC sidebar — sticky -->
      <aside class="hidden md:block shrink-0 w-[20%] border-r" style="border-color: var(--color-border);">
        <div class="sticky" style="top: 45px; max-height: calc(100vh - 45px); overflow-y: auto;">
          <nav class="py-8 px-8">
            <ul class="space-y-3">
              {tocEntries.map((entry) => (
                <li>
                  <a
                    href={`#${entry.slug}`}
                    class={`toc-link text-[14px] font-mono block py-0.5 transition-colors ${entry.level === 3 ? 'pl-3' : ''}`}
                    style="color: var(--color-text-tertiary); border-left: 2px solid transparent; padding-left: 8px;"
                    data-slug={entry.slug}
                  >
                    {entry.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </aside>

      <!-- Content -->
      <div class="flex-1 min-w-0 px-5 md:px-8 py-8">
        <div class="prose" set:html={html} />
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      var headings = document.querySelectorAll('.prose h2[id], .prose h3[id]');
      var tocLinks = document.querySelectorAll('.toc-link');

      if (!headings.length || !tocLinks.length) return;

      var currentActive = null;

      function setActive(slug) {
        if (slug === currentActive) return;
        currentActive = slug;
        tocLinks.forEach(function(link) {
          var isActive = link.getAttribute('data-slug') === slug;
          link.style.color = isActive ? 'var(--color-text)' : 'var(--color-text-tertiary)';
          link.style.borderLeftColor = isActive ? 'var(--color-text)' : 'transparent';
          link.style.fontWeight = isActive ? '500' : '400';
        });
      }

      function onScroll() {
        var found = null;
        for (var i = 0; i < headings.length; i++) {
          var rect = headings[i].getBoundingClientRect();
          if (rect.top <= 120) {
            found = headings[i].id;
          }
        }
        if (found) {
          setActive(found);
        }
      }

      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      tocLinks.forEach(function(link) {
        link.addEventListener('click', function(e) {
          e.preventDefault();
          var target = document.getElementById(link.getAttribute('data-slug'));
          if (target) {
            var y = target.getBoundingClientRect().top + window.scrollY - 60;
            window.scrollTo({ top: y, behavior: 'smooth' });
          }
        });
      });
    })();
  </script>
</Layout>
