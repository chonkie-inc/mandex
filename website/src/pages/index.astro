---
import Layout from '../layouts/Layout.astro';
import TerminalDemo from '../components/TerminalDemo.astro';

interface Package {
  name: string;
  description: string;
  latest_version: string;
  size_bytes: number;
  entry_count: number;
  version_count: number;
}

let packages: Package[] = [];
try {
  const res = await fetch('https://api.mandex.dev/packages');
  packages = await res.json();
} catch (e) {}

function formatSize(bytes: number): string {
  if (!bytes) return '—';
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(0) + ' KB';
  return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
}

// Total versions across all packages
const totalVersions = packages.reduce((sum, p) => sum + (p.version_count || 1), 0);

// Fill 4x5 = 20 cells, repeating if needed
const gridPackages: Package[] = [];
for (let i = 0; i < 20; i++) {
  gridPackages.push(packages[i % packages.length]);
}
