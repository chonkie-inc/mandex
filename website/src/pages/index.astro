---
import Layout from '../layouts/Layout.astro';
import TerminalDemo from '../components/TerminalDemo.astro';
---

<Layout title="mandex — documentation packages for AI agents">
  <!-- Single container with continuous left/right border lines -->
  <div class="flex-1 flex justify-center px-6 md:px-10 lg:px-16 pt-4 md:pt-6">
    <div
      class="relative w-full flex flex-col"
      style="max-width: 1400px; border-left: 1px solid var(--color-border); border-right: 1px solid var(--color-border);"
    >
      <!-- Top border line -->
      <div style="border-top: 1px solid var(--color-border);"></div>

      <!-- Corner crosshairs -->
      <svg class="absolute top-0 left-0 -translate-x-1/2 -translate-y-1/2" width="24" height="24" viewBox="0 0 24 24" fill="none">
        <line x1="12" y1="4" x2="12" y2="20" stroke="var(--color-text-tertiary)" stroke-width="1"/>
        <line x1="4" y1="12" x2="20" y2="12" stroke="var(--color-text-tertiary)" stroke-width="1"/>
      </svg>
      <svg class="absolute top-0 right-0 translate-x-1/2 -translate-y-1/2" width="24" height="24" viewBox="0 0 24 24" fill="none">
        <line x1="12" y1="4" x2="12" y2="20" stroke="var(--color-text-tertiary)" stroke-width="1"/>
        <line x1="4" y1="12" x2="20" y2="12" stroke="var(--color-text-tertiary)" stroke-width="1"/>
      </svg>

      <!-- Hero + Terminal area -->
      <div class="flex-1 flex items-center justify-center px-6 md:px-10 lg:px-16 py-12 md:py-16">
        <div class="flex flex-col md:flex-row gap-4 w-full" style="max-width: 1200px;">
          <!-- Hero -->
          <div
            class="md:basis-[45%] border flex flex-col justify-center gap-4 px-8 py-6 md:px-10 md:py-8 self-center"
            style="border-color: var(--color-border); background-color: var(--color-background);"
          >
            <h1
              class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight leading-[1.05]"
              style="color: var(--color-text);"
            >
              The <span style="color: #059669;">fastest</span> way for agents to get <span style="color: #059669;">docs</span>.
            </h1>
            <div class="h-px" style="background-color: var(--color-border);"></div>
            <p
              class="text-base md:text-lg leading-relaxed"
              style="color: var(--color-text-secondary);"
            >
              mandex pulls documentation as local docs indexes —
              one download gives you instant search, exact version
              pinning, and unlimited offline queries. No rate
              limits, no latency, no API keys.
            </p>
            <div class="h-px" style="background-color: var(--color-border);"></div>
            <div class="flex flex-wrap items-center gap-3">
              <button
                id="hero-copy"
                class="group flex items-center gap-2.5 px-4 py-2 border text-sm font-medium transition-colors cursor-pointer"
                style="background-color: #059669; color: white; border-color: #059669;"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
                </svg>
                <span class="text-[13px]">Copy install command</span>
              </button>
              <a
                href="https://github.com/chonkie-inc/mandex"
                target="_blank"
                rel="noopener"
                class="flex items-center gap-2 px-4 py-2 border text-sm font-medium transition-colors"
                style="border-color: var(--color-border); color: var(--color-text-secondary);"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                View on GitHub
              </a>
            </div>
          </div>

          <!-- Terminal Demo -->
          <div
            class="md:basis-[55%] overflow-hidden"
            style="height: 520px;"
          >
            <TerminalDemo />
          </div>
        </div>
      </div>

      <!-- Bottom border of box -->
      <div style="border-top: 1px solid var(--color-border);"></div>

      <!-- Integrates with section (inside the same vertical rails) -->
      <div>
        <!-- Divider with label -->
        <div class="relative flex items-center mb-3">
          <div class="flex-1 h-px" style="background-color: var(--color-border);"></div>
          <span
            class="pl-4 pr-1 text-[13px] font-mono"
            style="color: var(--color-text-tertiary);"
          >integrates with</span>
        </div>

        <!-- Logo marquee -->
        <div class="relative overflow-hidden" style="height: 80px;">
          <div class="absolute inset-y-0 left-0 w-20 z-10 pointer-events-none" style="background: linear-gradient(to right, var(--color-background), transparent);"></div>
          <div class="absolute inset-y-0 right-0 w-20 z-10 pointer-events-none" style="background: linear-gradient(to left, var(--color-background), transparent);"></div>

          <div class="flex items-center gap-14 h-full marquee-track">
            <div class="flex items-center gap-14 shrink-0">
              <img src="/agents/claude.svg" alt="Claude" class="h-16 opacity-40 hover:opacity-80 transition-opacity agent-logo" />
              <img src="/agents/cursor.svg" alt="Cursor" class="h-16 opacity-40 hover:opacity-80 transition-opacity agent-logo" />
              <img src="/agents/windsurf.svg" alt="Windsurf" class="h-16 opacity-40 hover:opacity-80 transition-opacity agent-logo" />
              <img src="/agents/codex.svg" alt="Codex" class="h-16 opacity-40 hover:opacity-80 transition-opacity agent-logo" />
              <img src="/agents/copilot.svg" alt="Copilot" class="h-16 opacity-40 hover:opacity-80 transition-opacity agent-logo" />
              <img src="/agents/gemini.svg" alt="Gemini" class="h-16 opacity-40 hover:opacity-80 transition-opacity agent-logo" />
              <img src="/agents/cline.svg" alt="Cline" class="h-16 opacity-40 hover:opacity-80 transition-opacity agent-logo" />
              <img src="/agents/openclaw.svg" alt="OpenClaw" class="h-16 opacity-40 hover:opacity-80 transition-opacity agent-logo" />
              <img src="/agents/amp.svg" alt="Amp" class="h-16 opacity-40 hover:opacity-80 transition-opacity agent-logo" />
              <img src="/agents/antigravity.svg" alt="Antigravity" class="h-16 opacity-40 hover:opacity-80 transition-opacity agent-logo" />
              <img src="/agents/clawdbot.svg" alt="Clawdbot" class="h-16 opacity-40 hover:opacity-80 transition-opacity agent-logo" />
            </div>
            <div class="flex items-center gap-14 shrink-0" aria-hidden="true">
              <img src="/agents/claude.svg" alt="Claude" class="h-16 opacity-40 agent-logo" />
              <img src="/agents/cursor.svg" alt="Cursor" class="h-16 opacity-40 agent-logo" />
              <img src="/agents/windsurf.svg" alt="Windsurf" class="h-16 opacity-40 agent-logo" />
              <img src="/agents/codex.svg" alt="Codex" class="h-16 opacity-40 agent-logo" />
              <img src="/agents/copilot.svg" alt="Copilot" class="h-16 opacity-40 agent-logo" />
              <img src="/agents/gemini.svg" alt="Gemini" class="h-16 opacity-40 agent-logo" />
              <img src="/agents/cline.svg" alt="Cline" class="h-16 opacity-40 agent-logo" />
              <img src="/agents/openclaw.svg" alt="OpenClaw" class="h-16 opacity-40 agent-logo" />
              <img src="/agents/amp.svg" alt="Amp" class="h-16 opacity-40 agent-logo" />
              <img src="/agents/antigravity.svg" alt="Antigravity" class="h-16 opacity-40 agent-logo" />
              <img src="/agents/clawdbot.svg" alt="Clawdbot" class="h-16 opacity-40 agent-logo" />
            </div>
          </div>
        </div>

        <!-- Bottom divider -->
        <div class="mt-3 h-px" style="background-color: var(--color-border);"></div>
      </div>
    </div>
  </div>

  <!-- Floating chonkie logo -->
  <a
    href="https://chonkie.ai"
    target="_blank"
    rel="noopener"
    class="fixed bottom-8 right-8 z-50 transition-opacity hover:opacity-80"
    style="pointer-events: auto;"
  >
    <img src="/chonkie-icon.png" alt="chonkie" class="h-14 object-contain" style="animation: spin 20s linear infinite;" />
  </a>

  <style>
    .marquee-track {
      animation: marquee-scroll 30s linear infinite;
    }
    @keyframes marquee-scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    /* SVG logos are light-colored (for dark bg), invert on light theme */
    [data-theme="light"] .agent-logo,
    :root:not([data-theme="dark"]) .agent-logo {
      filter: invert(1);
    }
    @media (prefers-color-scheme: dark) {
      :root:not([data-theme="light"]) .agent-logo {
        filter: none;
      }
    }
  </style>

  <script is:inline>
    document.getElementById('hero-copy')?.addEventListener('click', function() {
      var cmd = 'curl -fsSL https://mandex.dev/install.sh | sh';
      var btn = this;
      navigator.clipboard.writeText(cmd).then(function() {
        var original = btn.querySelector('span').textContent;
        btn.querySelector('span').textContent = 'Copied!';
        setTimeout(function() {
          btn.querySelector('span').textContent = original;
        }, 1500);
      });
    });
  </script>
</Layout>
