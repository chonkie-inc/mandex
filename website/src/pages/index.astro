---
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';
import BentoGrid from '../components/BentoGrid.astro';
---

<Layout title="mandex - documentation packages for AI agents">

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-8">
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-tight whitespace-nowrap" style="color: var(--color-text);">
      Docs shouldn't need a <span id="typed-word" style="color: var(--color-accent);"></span>
    </h1>
    <p class="mt-5 text-lg max-w-3xl leading-relaxed" style="color: var(--color-text-secondary);">
      AI agents make hundreds of doc lookups per session. Cloud MCP servers rate-limit you. Web scraping gets blocked. Mandex packages documentation into local, versioned indexes — one download, unlimited queries, always the right version.
    </p>
  </section>

  <!-- Terminal -->
  <section class="max-w-5xl mx-auto px-6 pb-10">
    <div class="max-w-3xl mx-auto">
      <Terminal />
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="flex flex-col items-center gap-3">
      <a href="/about" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-medium text-sm transition-colors" style="background-color: var(--color-text); color: var(--color-background);">
        Read the full post
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="/registry" class="text-sm transition-colors" style="color: var(--color-text-tertiary);" onmouseover="this.style.color=getComputedStyle(document.documentElement).getPropertyValue('--color-accent')" onmouseout="this.style.color=getComputedStyle(document.documentElement).getPropertyValue('--color-text-tertiary')">
        or browse available packages &rarr;
      </a>
    </div>
  </section>

  <!-- Features bento grid -->
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-24">
    <div class="mb-10">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight" style="color: var(--color-text);">What's in the box.</h2>
      <p class="mt-3 text-lg" style="color: var(--color-text-secondary);">No hand-waving. Here's exactly what mandex ships with.</p>
    </div>
    <BentoGrid />
  </section>

  <!-- Final CTA -->
  <section class="max-w-5xl mx-auto px-6 py-24 text-center border-t" style="border-color: var(--color-border);">
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-6" style="color: var(--color-text);">Ready to try it?</h2>
    <div class="inline-flex items-center gap-3 rounded-lg px-5 py-3 border" style="background-color: var(--color-background-secondary); border-color: var(--color-border);">
      <span class="select-none" style="color: var(--color-text-tertiary);">$</span>
      <code class="font-mono text-sm" style="color: var(--color-accent);">curl -fsSL https://mandex.dev/install.sh | sh</code>
      <button id="copy-final" class="transition-colors ml-2" style="color: var(--color-text-tertiary);" aria-label="Copy install command">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
        </svg>
      </button>
    </div>
  </section>

</Layout>

<script>
  const words = ['Server.', 'Key.', 'Proxy.', 'Scraper.', 'Token.', 'MCP.', 'Bot.', 'Plugin.', 'Cache.'];
  const el = document.getElementById('typed-word')!;

  let wordIndex = 0;
  let charIndex = 0;
  let deleting = false;

  const TYPE_SPEED = 80;
  const DELETE_SPEED = 45;
  const PAUSE_AFTER_TYPE = 1800;
  const PAUSE_AFTER_DELETE = 300;

  function tick() {
    const current = words[wordIndex];
    if (!deleting) {
      charIndex++;
      el.textContent = current.slice(0, charIndex);
      if (charIndex === current.length) {
        deleting = true;
        setTimeout(tick, PAUSE_AFTER_TYPE);
        return;
      }
      setTimeout(tick, TYPE_SPEED);
    } else {
      charIndex--;
      el.textContent = current.slice(0, charIndex);
      if (charIndex === 0) {
        deleting = false;
        wordIndex = (wordIndex + 1) % words.length;
        setTimeout(tick, PAUSE_AFTER_DELETE);
        return;
      }
      setTimeout(tick, DELETE_SPEED);
    }
  }

  tick();

  document.getElementById('copy-final')?.addEventListener('click', () => {
    navigator.clipboard.writeText('curl -fsSL https://mandex.dev/install.sh | sh');
    const btn = document.getElementById('copy-final')!;
    btn.style.color = getComputedStyle(document.documentElement).getPropertyValue('--color-accent');
    setTimeout(() => btn.style.color = '', 1200);
  });
</script>
