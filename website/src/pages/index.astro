---
import Layout from '../layouts/Layout.astro';

interface Package {
  name: string;
  description: string;
  latest_version: string;
  size_bytes: number;
}

let packages: Package[] = [];
try {
  const res = await fetch('https://api.mandex.dev/packages');
  packages = await res.json();
} catch (e) {
  // fallback if API is down
}

function formatSize(bytes: number): string {
  if (!bytes) return '—';
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(0) + ' KB';
  return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
}

// Build 8x5 grid; center 4x3 hole at cols 2-5, rows 1-3
// Row 0: 8 cells, Rows 1-3: 2 left + hole + 2 right, Row 4: 8 cells = 28 cells
const COLS = 8;
const ROWS = 5;
const HOLE_COL_START = 2;
const HOLE_COL_END = 6;
const HOLE_ROW_START = 1;
const HOLE_ROW_END = 4;

interface Cell {
  row: number;
  col: number;
  isHole: boolean;
  pkg: Package | null;
}

const cells: Cell[] = [];
let pkgIndex = 0;
for (let r = 0; r < ROWS; r++) {
  for (let c = 0; c < COLS; c++) {
    const isHole = c >= HOLE_COL_START && c < HOLE_COL_END && r >= HOLE_ROW_START && r < HOLE_ROW_END;
    let pkg: Package | null = null;
    if (!isHole && packages.length > 0) {
      pkg = packages[pkgIndex % packages.length];
      pkgIndex++;
    }
    cells.push({ row: r, col: c, isHole, pkg });
  }
}
---

<Layout title="mandex — documentation packages for AI agents">
  <div class="flex-1 flex flex-col min-h-0">
    <div class="flex-1 relative min-h-0 overflow-hidden">
      <!-- Grid of package cells -->
      <div
        class="absolute inset-x-0"
        style={`display: grid; grid-template-columns: repeat(${COLS}, 1fr); grid-template-rows: repeat(${ROWS}, calc((100vw - 96px) / 8)); top: 50%; transform: translateY(-50%);`}
      >
        {cells.map((cell) => (
          cell.isHole ? (
            <div></div>
          ) : (
            <a
              href={`/packages/${cell.pkg?.name}`}
              class="pkg-cell border flex flex-col items-center justify-center gap-1"
              style="border-color: var(--color-border); text-decoration: none;"
            >
              <span class="text-[13px] font-mono font-semibold" style="color: var(--color-text);">
                {cell.pkg?.name}
              </span>
              <span class="text-[11px] font-mono" style="color: var(--color-text-tertiary);">
                v{cell.pkg?.latest_version}
              </span>
              <span class="text-[10px] font-mono" style="color: var(--color-text-tertiary);">
                {cell.pkg ? formatSize(cell.pkg.size_bytes) : ''}
              </span>
            </a>
          )
        ))}
      </div>

      <!-- Hero box centered on top -->
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div
          class="border flex flex-col gap-5 px-10 py-8 pointer-events-auto"
          style="border-color: var(--color-border); max-width: 600px; width: 100%; background-color: var(--color-background);"
        >
          <h1
            class="text-4xl md:text-5xl font-bold tracking-tight leading-[1.05]"
            style="color: var(--color-text);"
          >
            The <span style="color: #059669;">fastest</span> way for agents to get <span style="color: #059669;">docs</span>.
          </h1>
          <div class="h-px" style="background-color: var(--color-border);"></div>
          <p
            class="text-base md:text-lg leading-relaxed"
            style="color: var(--color-text-secondary);"
          >
            mandex pulls documentation as local docs indexes —
            one download gives you instant search, exact version
            pinning, and unlimited offline queries. No rate
            limits, no latency, no API keys.
          </p>
          <div class="h-px" style="background-color: var(--color-border);"></div>
          <div class="flex flex-wrap items-center gap-3">
            <button
              id="hero-copy"
              class="group flex items-center gap-2.5 px-4 py-2 border text-sm font-medium transition-colors cursor-pointer"
              style="background-color: #059669; color: white; border-color: #059669;"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
              </svg>
              <span class="text-[13px]">Copy install command</span>
            </button>
            <a
              href="https://github.com/bhavnicksm/mandex"
              target="_blank"
              rel="noopener"
              class="flex items-center gap-2 px-4 py-2 border text-sm font-medium transition-colors"
              style="border-color: var(--color-border); color: var(--color-text-secondary);"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              View on GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Floating chonkie logo -->
  <a
    href="https://chonkie.ai"
    target="_blank"
    rel="noopener"
    class="fixed bottom-8 right-8 z-50 transition-opacity hover:opacity-80"
    style="pointer-events: auto;"
  >
    <img src="/chonkie-icon.png" alt="chonkie" class="h-14 object-contain" style="animation: spin 20s linear infinite;" />
  </a>

  <script is:inline>
    document.getElementById('hero-copy')?.addEventListener('click', function() {
      var cmd = 'curl -fsSL https://mandex.dev/install.sh | sh';
      var btn = this;
      navigator.clipboard.writeText(cmd).then(function() {
        var original = btn.querySelector('span').textContent;
        btn.querySelector('span').textContent = 'Copied!';
        setTimeout(function() {
          btn.querySelector('span').textContent = original;
        }, 1500);
      });
    });

  </script>
</Layout>
