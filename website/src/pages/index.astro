---
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';
---

<Layout title="mandex - documentation packages for AI agents">
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-8 text-center">
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-tight" style="color: var(--color-text);">
      Docs shouldn't need a <span id="typed-word" style="color: var(--color-accent); display: inline-block; min-width: 5ch;"></span>
    </h1>
    <p class="mt-5 text-lg max-w-3xl mx-auto leading-relaxed" style="color: var(--color-text-secondary);">
      AI agents make hundreds of doc lookups per session. Cloud MCP servers rate-limit you. Web scraping gets blocked. Mandex packages documentation into local, versioned indexes — one download, unlimited queries, always the right version.
    </p>
  </section>

  <!-- Terminal hero -->
  <section class="max-w-5xl mx-auto px-6 pb-8">
    <div class="max-w-3xl mx-auto">
      <Terminal />
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-6 pb-16">
    <div class="flex flex-col items-center gap-3">
      <a href="/about" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-medium text-sm transition-colors" style="background-color: var(--color-text); color: var(--color-background);">
        Read the full post
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="/registry" class="text-sm transition-colors" style="color: var(--color-text-tertiary);" onmouseover="this.style.color=getComputedStyle(document.documentElement).getPropertyValue('--color-accent')" onmouseout="this.style.color=getComputedStyle(document.documentElement).getPropertyValue('--color-text-tertiary')">
        or browse available packages &rarr;
      </a>
    </div>
  </section>

  <!-- Bento grid -->
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-24">
    <div class="bento-grid">

      <!-- Cell 1: Works with your agent (2-col wide) -->
      <div class="bento-cell bento-wide" style="background-color: var(--color-background-secondary); border-color: var(--color-border);">
        <p class="bento-label">Works with your agent</p>
        <div class="agent-logos">
          <!-- Anthropic / Claude Code -->
          <div class="agent-badge" title="Claude Code">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.3041 3.541h-3.6718l6.696 16.918H24Zm-10.6082 0L0 20.459h3.7442l1.3693-3.5527h7.0052l1.3693 3.5528h3.7442L10.5363 3.5409Zm-.3712 10.2232 2.2914-5.9456 2.2914 5.9456Z"/>
            </svg>
            <span>Claude Code</span>
          </div>
          <!-- Cursor -->
          <div class="agent-badge" title="Cursor">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M11.503.131 1.891 5.678a.84.84 0 0 0-.42.726v11.188c0 .3.162.575.42.724l9.609 5.55a1 1 0 0 0 .998 0l9.61-5.55a.84.84 0 0 0 .42-.724V6.404a.84.84 0 0 0-.42-.726L12.497.131a1.01 1.01 0 0 0-.996 0M2.657 6.338h18.55c.263 0 .43.287.297.515L12.23 22.918c-.062.107-.229.064-.229-.06V12.335a.59.59 0 0 0-.295-.51l-9.11-5.257c-.109-.063-.064-.23.061-.23"/>
            </svg>
            <span>Cursor</span>
          </div>
          <!-- Windsurf -->
          <div class="agent-badge" title="Windsurf">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.55 5.067c-1.2038-.002-2.1806.973-2.1806 2.1765v4.8676c0 .972-.8035 1.7594-1.7597 1.7594-.568 0-1.1352-.286-1.4718-.7659l-4.9713-7.1003c-.4125-.5896-1.0837-.941-1.8103-.941-1.1334 0-2.1533.9635-2.1533 2.153v4.8957c0 .972-.7969 1.7594-1.7596 1.7594-.57 0-1.1363-.286-1.4728-.7658L.4076 5.1598C.2822 4.9798 0 5.0688 0 5.2882v4.2452c0 .2147.0656.4228.1884.599l5.4748 7.8183c.3234.462.8006.8052 1.3509.9298 1.3771.313 2.6446-.747 2.6446-2.0977v-4.893c0-.972.7875-1.7593 1.7596-1.7593h.003a1.798 1.798 0 0 1 1.4718.7658l4.9723 7.0994c.4135.5905 1.05.941 1.8093.941 1.1587 0 2.1515-.9645 2.1515-2.153v-4.8948c0-.972.7875-1.7594 1.7596-1.7594h.194a.22.22 0 0 0 .2204-.2202v-4.622a.22.22 0 0 0-.2203-.2203Z"/>
            </svg>
            <span>Windsurf</span>
          </div>
          <!-- OpenAI Codex -->
          <div class="agent-badge" title="Codex">
            <svg width="22" height="22" viewBox="0 0 297 320" fill="currentColor">
              <path d="M297.06 130.97c7.26-21.79 4.76-45.66-6.85-65.48-17.46-30.4-52.56-46.04-86.84-38.68-15.25-17.18-37.16-26.95-60.13-26.81-35.04-.08-66.13 22.48-76.91 55.82-22.51 4.61-41.94 18.7-53.31 38.67-17.59 30.32-13.58 68.54 9.92 94.54-7.26 21.79-4.76 45.66 6.85 65.48 17.46 30.4 52.56 46.04 86.84 38.68 15.24 17.18 37.16 26.95 60.13 26.8 35.06.09 66.16-22.49 76.94-55.86 22.51-4.61 41.94-18.7 53.31-38.67 17.57-30.32 13.55-68.51-9.94-94.51zm-120.28 168.11c-14.03.02-27.62-4.89-38.39-13.88.49-.26 1.34-.73 1.89-1.07l63.72-36.8c3.26-1.85 5.26-5.32 5.24-9.07v-89.83l26.93 15.55c.29.14.48.42.52.74v74.39c-.04 33.08-26.83 59.9-59.91 59.97zm-128.84-55.03c-7.03-12.14-9.56-26.37-7.15-40.18.47.28 1.3.79 1.89 1.13l63.72 36.8c3.23 1.89 7.23 1.89 10.47 0l77.79-44.92v31.1c.02.32-.13.63-.38.83l-64.41 37.19c-28.69 16.52-65.33 6.7-81.92-21.95zm-16.77-139.09c7-12.16 18.05-21.46 31.21-26.29 0 .55-.03 1.52-.03 2.2v73.61c-.02 3.74 1.98 7.21 5.23 9.06l77.79 44.91-26.93 15.55c-.27.18-.61.21-.91.08l-64.42-37.22c-28.63-16.58-38.45-53.21-21.95-81.89zm221.26 51.49-77.79-44.92 26.93-15.54c.27-.18.61-.21.91-.08l64.42 37.19c28.68 16.57 38.51 53.26 21.94 81.94-7.01 12.14-18.05 21.44-31.2 26.28v-75.81c.03-3.74-1.96-7.2-5.2-9.06zm26.8-40.34c-.47-.29-1.3-.79-1.89-1.13l-63.72-36.8c-3.23-1.89-7.23-1.89-10.47 0l-77.79 44.92v-31.1c-.02-.32.13-.63.38-.83l64.41-37.16c28.69-16.55 65.37-6.7 81.91 22 6.99 12.12 9.52 26.31 7.15 40.1zm-168.51 55.43-26.94-15.55c-.29-.14-.48-.42-.52-.74v-74.39c.02-33.12 26.89-59.96 60.01-59.94 14.01 0 27.57 4.92 38.34 13.88-.49.26-1.33.73-1.89 1.07l-63.72 36.8c-3.26 1.85-5.26 5.31-5.24 9.06l-.04 89.79zm14.63-31.54 34.65-20.01 34.65 20v40.01l-34.65 20-34.65-20z"/>
            </svg>
            <span>Codex</span>
          </div>
        </div>
      </div>

      <!-- Row 1, Cell 2: Sub-millisecond search -->
      <div class="bento-cell" style="background-color: var(--color-background-secondary); border-color: var(--color-border);">
        <p class="bento-label">Search speed</p>
        <p class="bento-stat" style="color: var(--color-accent);">&lt; 1ms</p>
        <p class="bento-sub">local FTS5 + BM25</p>
      </div>

      <!-- Row 1, Cell 3: Zero rate limits -->
      <div class="bento-cell" style="background-color: var(--color-background-secondary); border-color: var(--color-border);">
        <p class="bento-label">Rate limits</p>
        <p class="bento-stat" style="color: var(--color-accent);">∞</p>
        <p class="bento-sub">unlimited queries</p>
      </div>

      <!-- Row 2, Cell 4: Version-pinned (small) -->
      <div class="bento-cell" style="background-color: var(--color-background-secondary); border-color: var(--color-border);">
        <p class="bento-label">Version-pinned</p>
        <p class="bento-code" style="color: var(--color-accent); background-color: var(--color-background); margin-top: 0.5rem; font-size: 0.85rem;">pytorch@2.3.0</p>
        <p class="bento-sub">always the right version</p>
      </div>

      <!-- Row 2, Cell 5: Zero config (small) -->
      <div class="bento-cell" style="background-color: var(--color-background-secondary); border-color: var(--color-border);">
        <p class="bento-label">Zero config</p>
        <p class="bento-code" style="color: var(--color-accent); background-color: var(--color-background); margin-top: 0.5rem; font-size: 0.85rem;">mx sync</p>
        <p class="bento-sub">pulls docs for your project</p>
      </div>

      <!-- Row 2, Cell 6: Open registry (wide) -->
      <div class="bento-cell bento-wide" style="background-color: var(--color-background-secondary); border-color: var(--color-border);">
        <p class="bento-label">Open registry</p>
        <div style="display: flex; align-items: baseline; gap: 1rem; margin: 0.5rem 0;">
          <p class="bento-stat" style="color: var(--color-accent); margin: 0;">11</p>
          <p style="color: var(--color-text-secondary); font-size: 1rem; margin: 0;">packages and growing</p>
        </div>
        <div style="display: flex; gap: 0.5rem; margin-top: 0.75rem; flex-wrap: wrap;">
          <span class="eco-tag npm">npm</span>
          <span class="eco-tag pip">pip</span>
          <span class="eco-tag cargo">cargo</span>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  /* ── Bento grid ─────────────────────────────────── */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .bento-cell {
    border: 1px solid;
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transition: opacity 0.2s;
  }
  .bento-cell:hover { opacity: 0.85; }

  .bento-wide { grid-column: span 2; }

  .bento-label {
    font-size: 0.7rem;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin: 0;
  }

  .bento-stat {
    font-size: 2.75rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0.4rem 0 0;
    font-family: 'Inter', sans-serif;
  }

  .bento-sub {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    margin: 0.25rem 0 0;
  }

  .bento-code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.1rem;
    font-weight: 600;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    display: inline-block;
    margin: 0.5rem 0 0;
    letter-spacing: -0.01em;
  }

  /* Agent logos cell */
  .agent-logos {
    display: flex;
    gap: 1.25rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .agent-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-text-secondary);
    transition: color 0.15s;
  }
  .agent-badge:hover { color: var(--color-text); }
  .agent-badge span {
    font-size: 0.65rem;
    font-family: 'JetBrains Mono', monospace;
    color: var(--color-text-tertiary);
    white-space: nowrap;
  }

  /* Ecosystem tags */
  .eco-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    border: 1px solid;
  }
  .eco-tag.npm    { color: #ef4444; border-color: rgba(239,68,68,0.3); background: rgba(239,68,68,0.08); }
  .eco-tag.pip    { color: #3b82f6; border-color: rgba(59,130,246,0.3); background: rgba(59,130,246,0.08); }
  .eco-tag.cargo  { color: #f97316; border-color: rgba(249,115,22,0.3); background: rgba(249,115,22,0.08); }

  @media (max-width: 640px) {
    .bento-grid { grid-template-columns: repeat(2, 1fr); }
    .bento-wide { grid-column: span 2; }
  }

</style>

<script>
  const words = ['Server.', 'Key.', 'Proxy.', 'Scraper.', 'Token.', 'MCP.', 'Bot.', 'Plugin.', 'Cache.'];
  const el = document.getElementById('typed-word')!;

  let wordIndex = 0;
  let charIndex = 0;
  let deleting = false;

  const TYPE_SPEED = 80;
  const DELETE_SPEED = 45;
  const PAUSE_AFTER_TYPE = 1800;
  const PAUSE_AFTER_DELETE = 300;

  function tick() {
    const current = words[wordIndex];

    if (!deleting) {
      charIndex++;
      el.textContent = current.slice(0, charIndex);
      if (charIndex === current.length) {
        deleting = true;
        setTimeout(tick, PAUSE_AFTER_TYPE);
        return;
      }
      setTimeout(tick, TYPE_SPEED);
    } else {
      charIndex--;
      el.textContent = current.slice(0, charIndex);
      if (charIndex === 0) {
        deleting = false;
        wordIndex = (wordIndex + 1) % words.length;
        setTimeout(tick, PAUSE_AFTER_DELETE);
        return;
      }
      setTimeout(tick, DELETE_SPEED);
    }
  }

  tick();
</script>
