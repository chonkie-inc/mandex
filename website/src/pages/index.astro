---
import Layout from '../layouts/Layout.astro';
---

<Layout title="mandex - documentation packages for AI agents">
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-8 text-center">
    <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight leading-tight" style="color: var(--color-text);">
      Docs shouldn't need an API.
    </h1>
    <p class="mt-4 text-base max-w-2xl mx-auto leading-relaxed" style="color: var(--color-text-secondary);">
      AI agents make hundreds of doc lookups per session. Cloud servers rate-limit you. Web scraping gets blocked. Mandex packages documentation into local, versioned indexes — one download, unlimited queries, always the right version.
    </p>
  </section>

  <!-- Terminal hero -->
  <section class="max-w-3xl mx-auto px-6 pb-8">
    <div id="terminal-wrapper" class="terminal-window cursor-pointer relative group">
      <!-- Title bar -->
      <div class="terminal-titlebar">
        <div class="terminal-dots">
          <span class="terminal-dot terminal-dot-close"></span>
          <span class="terminal-dot terminal-dot-minimize"></span>
          <span class="terminal-dot terminal-dot-expand"></span>
        </div>
        <span class="terminal-title">mandex</span>
        <!-- Copy hint -->
        <span id="copy-hint" class="terminal-copy-hint">
          click to copy install command
        </span>
      </div>
      <!-- Terminal body -->
      <div id="terminal" class="terminal-body">
        <div id="terminal-lines"></div>
        <div id="cursor-line" class="flex">
          <span class="terminal-prompt">$</span>&nbsp;<span id="typing-target"></span><span id="cursor" class="cursor-blink">&#9608;</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-3xl mx-auto px-6 pb-16">
    <div class="flex justify-center">
      <a href="/about" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-medium text-sm transition-colors" style="background-color: var(--color-text); color: var(--color-background);">
        Read the full post
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</Layout>

<style>
  /* Terminal window */
  .terminal-window {
    border-radius: 10px;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.08),
      0 8px 40px rgba(0, 0, 0, 0.08),
      0 2px 8px rgba(0, 0, 0, 0.04);
    transition: box-shadow 0.3s ease;
  }
  .terminal-window:hover {
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.1),
      0 12px 48px rgba(0, 0, 0, 0.12),
      0 4px 12px rgba(0, 0, 0, 0.06);
  }

  /* Title bar */
  .terminal-titlebar {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    background: #f0f0f0;
    border-bottom: 1px solid #d9d9d9;
    position: relative;
  }

  /* Traffic light dots */
  .terminal-dots {
    display: flex;
    gap: 8px;
  }
  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    position: relative;
  }
  .terminal-dot-close {
    background: #ff5f57;
    border: 1px solid #e0443e;
  }
  .terminal-dot-minimize {
    background: #febc2e;
    border: 1px solid #dea123;
  }
  .terminal-dot-expand {
    background: #28c840;
    border: 1px solid #1dad2b;
  }

  /* Title text */
  .terminal-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-size: 13px;
    font-family: 'Inter', -apple-system, sans-serif;
    color: #999;
    user-select: none;
  }

  /* Copy hint */
  .terminal-copy-hint {
    margin-left: auto;
    font-size: 11px;
    font-family: 'Inter', -apple-system, sans-serif;
    color: #bbb;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .terminal-window:hover .terminal-copy-hint {
    opacity: 1;
  }

  /* Terminal body */
  .terminal-body {
    background: #1a1a2e;
    padding: 20px 24px;
    font-family: 'JetBrains Mono', 'SF Mono', 'Menlo', 'Monaco', 'Consolas', monospace;
    font-size: 13.5px;
    line-height: 1.7;
    height: 360px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    color: #c8c8d0;
    box-shadow: inset 0 1px 4px rgba(0, 0, 0, 0.2);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Prompt color */
  .terminal-prompt {
    color: var(--color-accent);
  }

  /* Cursor */
  .cursor-blink {
    animation: blink 1s step-end infinite;
    font-weight: normal;
    color: #c8c8d0;
    opacity: 0.8;
  }
  @keyframes blink {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 0; }
  }

  /* Dark mode adjustments */
  @media (prefers-color-scheme: dark) {
    .terminal-window {
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.06),
        0 8px 40px rgba(0, 0, 0, 0.4),
        0 2px 8px rgba(0, 0, 0, 0.3);
    }
    .terminal-window:hover {
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.08),
        0 12px 48px rgba(0, 0, 0, 0.5),
        0 4px 12px rgba(0, 0, 0, 0.35);
    }
    .terminal-titlebar {
      background: #2a2a2a;
      border-bottom-color: #1a1a1a;
    }
    .terminal-dot-close {
      background: #ff5f57;
      border-color: #c7443e;
    }
    .terminal-dot-minimize {
      background: #febc2e;
      border-color: #c49a23;
    }
    .terminal-dot-expand {
      background: #28c840;
      border-color: #1a9d2b;
    }
    .terminal-title {
      color: #666;
    }
    .terminal-copy-hint {
      color: #555;
    }
    .terminal-body {
      background: #0d0d1a;
      box-shadow: inset 0 1px 4px rgba(0, 0, 0, 0.5);
      color: #b0b0c0;
    }
    .cursor-blink {
      color: #b0b0c0;
    }
  }
</style>

<script>
  // Terminal uses its own color palette (always dark background)
  const accentColor = '#34d399';
  const textColor = '#e0e0ea';
  const secondaryColor = '#8888a0';
  const tertiaryColor = '#5a5a72';

  interface Step {
    type: 'command' | 'output' | 'blank' | 'pause';
    text?: string;
    color?: string;
    delay?: number;
  }

  const sequence: Step[] = [
    { type: 'command', text: 'curl -fsSL https://mandex.dev/install.sh | sh' },
    { type: 'output', text: 'Installing mandex (mx)...', color: secondaryColor },
    { type: 'output', text: '✓ Installed mx to /usr/local/bin/mx', color: accentColor },
    { type: 'blank' },
    { type: 'pause', delay: 600 },
    { type: 'command', text: 'mx pull pytorch@2.3.0' },
    { type: 'output', text: '↓ pytorch@2.3.0  3.8 MB  [===========] done', color: secondaryColor },
    { type: 'output', text: 'Installed to ~/.mandex/cache/pytorch/2.3.0.db', color: secondaryColor },
    { type: 'blank' },
    { type: 'pause', delay: 600 },
    { type: 'command', text: 'mx search pytorch "attention mechanism"' },
    { type: 'output', text: '<accent>pytorch@2.3.0</accent> — MultiheadAttention', color: secondaryColor },
    { type: 'output', text: 'Allows the model to jointly attend to information', color: secondaryColor },
    { type: 'output', text: 'from different representation subspaces...', color: secondaryColor },
    { type: 'output', text: '', color: secondaryColor },
    { type: 'output', text: '<accent>pytorch@2.3.0</accent> — ScaledDotProductAttention', color: secondaryColor },
    { type: 'output', text: 'Computes scaled dot-product attention on query,', color: secondaryColor },
    { type: 'output', text: 'key, and value tensors...', color: secondaryColor },
    { type: 'blank' },
    { type: 'pause', delay: 800 },
    { type: 'command', text: 'mx sync' },
    { type: 'output', text: 'Reading requirements.txt...', color: secondaryColor },
    { type: 'output', text: 'Resolved 8 dependencies to mandex packages', color: secondaryColor },
    { type: 'output', text: '✓ All packages up to date', color: accentColor },
  ];

  const linesContainer = document.getElementById('terminal-lines')!;
  const typingTarget = document.getElementById('typing-target')!;
  const cursorLine = document.getElementById('cursor-line')!;
  const copyHint = document.getElementById('copy-hint')!;

  function sleep(ms: number): Promise<void> {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  function addOutputLine(text: string, color: string): void {
    const line = document.createElement('div');
    const processed = text.replace(/<accent>(.*?)<\/accent>/g, `<span style="color:${accentColor}">$1</span>`);
    line.innerHTML = processed;
    line.style.color = color;
    line.style.paddingLeft = '1.1em';
    linesContainer.appendChild(line);
  }

  function addBlankLine(): void {
    const line = document.createElement('div');
    line.innerHTML = '&nbsp;';
    linesContainer.appendChild(line);
  }

  function commitCommandLine(text: string): void {
    const line = document.createElement('div');
    line.innerHTML = `<span style="color:${accentColor}">$</span> <span style="color:${textColor}">${text}</span>`;
    linesContainer.appendChild(line);
  }

  async function typeText(text: string): Promise<void> {
    typingTarget.textContent = '';
    for (let i = 0; i < text.length; i++) {
      typingTarget.textContent = text.slice(0, i + 1);
      const charDelay = 25 + Math.random() * 35;
      await sleep(charDelay);
    }
  }

  async function runSequence(): Promise<void> {
    for (const step of sequence) {
      if (step.type === 'command') {
        cursorLine.style.display = 'flex';
        await typeText(step.text!);
        await sleep(300);
        cursorLine.style.display = 'none';
        commitCommandLine(step.text!);
        typingTarget.textContent = '';
        await sleep(150);
      } else if (step.type === 'output') {
        addOutputLine(step.text!, step.color || secondaryColor);
        await sleep(60);
      } else if (step.type === 'blank') {
        addBlankLine();
      } else if (step.type === 'pause') {
        cursorLine.style.display = 'flex';
        typingTarget.textContent = '';
        await sleep(step.delay || 500);
      }
    }
    cursorLine.style.display = 'flex';
    typingTarget.textContent = '';

    await sleep(4000);
    linesContainer.innerHTML = '';
    await sleep(500);
    runSequence();
  }

  // Click terminal to copy install command
  document.getElementById('terminal-wrapper')?.addEventListener('click', () => {
    navigator.clipboard.writeText('curl -fsSL https://mandex.dev/install.sh | sh');
    const original = copyHint.textContent;
    copyHint.textContent = 'copied!';
    copyHint.style.opacity = '1';
    setTimeout(() => {
      copyHint.textContent = original;
      copyHint.style.opacity = '';
    }, 1500);
  });

  runSequence();
</script>
