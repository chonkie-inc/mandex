---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  let packages: { name: string }[] = [];
  try {
    const res = await fetch('https://api.mandex.dev/packages');
    packages = await res.json();
  } catch (e) {}

  return packages.map((pkg) => ({
    params: { name: pkg.name },
  }));
}

const pkgName = Astro.params.name;
---

<Layout title={`${pkgName} — mandex`} description="">
  <div class="flex-1 flex flex-col min-h-0 overflow-y-auto">
    <!-- Back link -->
    <div class="shrink-0 px-5 py-2.5 border-b" style="border-color: var(--color-border);">
      <a
        href="/registry"
        class="inline-flex items-center gap-1.5 text-[13px] font-mono transition-opacity hover:opacity-70"
        style="color: var(--color-text-secondary);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        Back to registry
      </a>
    </div>

    <div id="pkg-content">
      <div class="px-5 py-8 text-center font-mono text-sm" style="color: var(--color-text-tertiary);" id="loading-msg">
        Loading package details...
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ pkgName }}>
    (function() {
      var contentEl = document.getElementById('pkg-content');
      var loadingEl = document.getElementById('loading-msg');

      function formatSize(bytes) {
        if (!bytes) return '\u2014';
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(0) + ' KB';
        return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
      }

      function formatDate(iso) {
        var d = new Date(iso);
        return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
      }

      function renderPackage(pkg) {
        if (!pkg) {
          if (loadingEl) loadingEl.textContent = 'Package not found.';
          return;
        }

        var versions = pkg.versions || [];
        var latest = versions.length > 0 ? versions[0].version : null;

        var html = '';

        html += '<div class="shrink-0 px-5 py-6 border-b" style="border-color: var(--color-border);">';
        html += '<div class="flex items-start justify-between gap-4 flex-wrap">';
        html += '<div class="flex flex-col gap-2">';
        html += '<div class="flex items-center gap-3">';
        html += '<h1 class="text-3xl md:text-4xl font-bold tracking-tight" style="color: var(--color-text);">' + pkg.name + '</h1>';
        html += '<span class="font-mono text-[11px] font-medium uppercase tracking-widest px-2 py-0.5 border" style="color: var(--color-text-secondary); border-color: var(--color-border); background-color: var(--color-background-secondary);">' + (pkg.ecosystem || '') + '</span>';
        if (pkg.downloads > 0) {
          html += '<span class="font-mono text-[11px] px-2 py-0.5" style="color: var(--color-text-tertiary);">' + pkg.downloads.toLocaleString() + ' pulls</span>';
        }
        html += '</div>';
        if (pkg.description) {
          html += '<p class="text-base leading-relaxed max-w-xl" style="color: var(--color-text-secondary);">' + pkg.description + '</p>';
        }
        html += '</div>';
        if (pkg.source_url) {
          html += '<a href="' + pkg.source_url + '" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-3 py-1.5 border text-[13px] font-mono transition-colors shrink-0" style="border-color: var(--color-border); color: var(--color-text-secondary); text-decoration: none;">';
          html += '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>';
          html += 'Source</a>';
        }
        html += '</div></div>';

        html += '<div class="shrink-0 px-5 py-4 border-b" style="border-color: var(--color-border);">';
        html += '<div class="flex items-center gap-2 mb-2">';
        html += '<span class="text-[11px] font-mono font-medium uppercase tracking-widest" style="color: var(--color-text-tertiary);">Install</span>';
        html += '</div>';
        html += '<div class="flex items-center justify-between border px-4 py-3" style="border-color: var(--color-border); background-color: var(--color-background-secondary);">';
        html += '<code class="font-mono text-sm" style="color: var(--color-text);">mx pull ' + pkg.name + '</code>';
        html += '<button id="copy-install" class="shrink-0 p-1.5 cursor-pointer transition-opacity hover:opacity-70" style="color: var(--color-text-secondary);" title="Copy command">';
        html += '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';
        html += '</button></div></div>';

        html += '<div class="px-5 py-2.5 border-b shrink-0 flex items-center gap-2" style="border-color: var(--color-border);">';
        html += '<span class="text-[11px] font-mono font-medium uppercase tracking-widest" style="color: var(--color-text-tertiary);">Versions</span>';
        html += '<span class="text-[11px] font-mono ml-1" style="color: var(--color-text-tertiary);">(' + versions.length + ')</span>';
        html += '</div>';

        html += '<div class="shrink-0 grid grid-cols-4 px-5 py-2 border-b font-mono text-[11px] font-medium uppercase tracking-widest" style="border-color: var(--color-border); color: var(--color-text-tertiary);">';
        html += '<span>Version</span><span class="text-right">Entries</span><span class="text-right">Size</span><span class="text-right">Published</span>';
        html += '</div>';

        html += '<div class="flex-1 overflow-y-auto">';
        versions.forEach(function(v) {
          var isLatest = v.version === latest;
          var bg = isLatest ? 'background-color: var(--color-background-secondary);' : '';
          html += '<div class="grid grid-cols-4 px-5 py-2.5 border-b font-mono text-[13px] transition-colors" style="border-color: var(--color-border);' + bg + '">';
          html += '<span class="flex items-center gap-2" style="color: var(--color-text);">' + v.version;
          if (isLatest) {
            html += ' <span class="text-[10px] font-medium uppercase tracking-wider px-1.5 py-0.5 border" style="color: var(--color-text-secondary); border-color: var(--color-border);">latest</span>';
          }
          html += '</span>';
          html += '<span class="text-right" style="color: var(--color-text-secondary);">' + (v.entry_count ? v.entry_count.toLocaleString() : '\u2014') + '</span>';
          html += '<span class="text-right" style="color: var(--color-text-secondary);">' + formatSize(v.size_bytes) + '</span>';
          html += '<span class="text-right" style="color: var(--color-text-tertiary);">' + formatDate(v.published_at) + '</span>';
          html += '</div>';
        });
        html += '</div>';

        contentEl.innerHTML = html;

        var copyBtn = document.getElementById('copy-install');
        if (copyBtn) {
          copyBtn.addEventListener('click', function() {
            navigator.clipboard.writeText('mx pull ' + pkg.name).then(function() {
              copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
              setTimeout(function() {
                copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';
              }, 1500);
            });
          });
        }
      }

      fetch('https://api.mandex.dev/packages/' + pkgName)
        .then(function(res) {
          if (!res.ok) throw new Error('Not found');
          return res.json();
        })
        .then(function(data) {
          if (loadingEl) loadingEl.remove();
          renderPackage(data);
        })
        .catch(function() {
          if (loadingEl) loadingEl.textContent = 'Package not found.';
        });
    })();
  </script>
</Layout>
