---
import Layout from '../layouts/Layout.astro';

interface Package {
  name: string;
  description: string;
  latest_version: string;
  size_bytes: number;
}

const res = await fetch('https://api.mandex.dev/packages');
const packages: Package[] = await res.json();

function formatSize(bytes: number): string {
  if (!bytes) return '\u2014';
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(0) + ' KB';
  return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
}
---

<Layout title="mandex — Registry">
  <div class="flex-1 flex flex-col min-h-0 overflow-y-auto">
    <!-- Back link -->
    <div
      class="shrink-0 px-5 py-2.5 border-b"
      style="border-color: var(--color-border);"
    >
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-[13px] font-mono transition-opacity hover:opacity-70"
        style="color: var(--color-text-secondary);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        Back
      </a>
    </div>

    <!-- Header area -->
    <div class="shrink-0 px-5 py-5 border-b" style="border-color: var(--color-border);">
      <div class="flex items-center gap-2 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-text-tertiary);">
          <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" x2="12" y1="22" y2="12"/>
        </svg>
        <span
          class="text-[11px] font-mono font-medium uppercase tracking-widest"
          style="color: var(--color-text-tertiary);"
        >
          Registry
        </span>
      </div>

      <!-- Search bar -->
      <input
        id="search-input"
        type="text"
        placeholder="Search packages..."
        class="w-full px-4 py-2.5 border font-mono text-sm outline-none"
        style="border-color: var(--color-border); background-color: var(--color-background-secondary); color: var(--color-text); border-radius: 0;"
      />

      <!-- Package count -->
      <div class="mt-3">
        <span
          class="text-[12px] font-mono"
          style="color: var(--color-text-tertiary);"
          id="package-count"
        >
          {packages.length} packages
        </span>
      </div>
    </div>

    <!-- Package list -->
    <div class="flex-1 min-h-0 overflow-y-auto">
      {packages.map((pkg) => (
        <a
          href={`/packages/${pkg.name}`}
          class="package-row flex items-center justify-between px-5 py-3 border-b transition-colors"
          style="border-color: var(--color-border); text-decoration: none;"
          data-name={pkg.name.toLowerCase()}
          data-description={(pkg.description || '').toLowerCase()}
          onmouseenter="this.style.backgroundColor='var(--color-background-secondary)'"
          onmouseleave="this.style.backgroundColor=''"
        >
          <div class="flex flex-col min-w-0 mr-4">
            <span
              class="font-mono text-[13px] font-semibold"
              style="color: var(--color-text);"
            >
              {pkg.name}
            </span>
            {pkg.description && (
              <span
                class="text-[12px] mt-0.5 truncate"
                style="color: var(--color-text-tertiary);"
              >
                {pkg.description}
              </span>
            )}
          </div>
          <div class="flex flex-col items-end shrink-0">
            <span
              class="font-mono text-[12px]"
              style="color: var(--color-text-secondary);"
            >
              {pkg.latest_version}
            </span>
            <span
              class="font-mono text-[11px] mt-0.5"
              style="color: var(--color-text-tertiary);"
            >
              {formatSize(pkg.size_bytes)}
            </span>
          </div>
        </a>
      ))}

      {packages.length === 0 && (
        <div
          class="px-5 py-8 text-center font-mono text-sm"
          style="color: var(--color-text-tertiary);"
        >
          No packages found.
        </div>
      )}

      <!-- No results message (hidden by default) -->
      <div
        id="no-results"
        class="px-5 py-8 text-center font-mono text-sm"
        style="color: var(--color-text-tertiary); display: none;"
      >
        No matching packages.
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      var input = document.getElementById('search-input');
      var rows = document.querySelectorAll('.package-row');
      var countEl = document.getElementById('package-count');
      var noResults = document.getElementById('no-results');
      var total = rows.length;

      input.addEventListener('input', function() {
        var query = input.value.toLowerCase().trim();
        var visible = 0;

        rows.forEach(function(row) {
          var name = row.getAttribute('data-name') || '';
          var desc = row.getAttribute('data-description') || '';
          var match = !query || name.indexOf(query) !== -1 || desc.indexOf(query) !== -1;
          row.style.display = match ? '' : 'none';
          if (match) visible++;
        });

        if (countEl) {
          countEl.textContent = visible + ' package' + (visible !== 1 ? 's' : '');
        }
        if (noResults) {
          noResults.style.display = visible === 0 ? '' : 'none';
        }
      });
    })();
  </script>
</Layout>
