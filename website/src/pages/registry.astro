---
import Layout from '../layouts/Layout.astro';
import registry from '../data/registry.json';

const ecosystemColors: Record<string, { bg: string; text: string; border: string }> = {
  npm: { bg: 'rgba(239, 68, 68, 0.1)', text: '#ef4444', border: 'rgba(239, 68, 68, 0.2)' },
  pip: { bg: 'rgba(59, 130, 246, 0.1)', text: '#3b82f6', border: 'rgba(59, 130, 246, 0.2)' },
  cargo: { bg: 'rgba(249, 115, 22, 0.1)', text: '#f97316', border: 'rgba(249, 115, 22, 0.2)' },
  go: { bg: 'rgba(6, 182, 212, 0.1)', text: '#06b6d4', border: 'rgba(6, 182, 212, 0.2)' },
};
---

<Layout title="Registry - mandex" description="Browse available documentation packages.">
  <section class="max-w-5xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold mb-2" style="color: var(--color-text);">Registry</h1>
    <p class="mb-10" style="color: var(--color-text-secondary);">
      Available documentation packages. Install with
      <code class="text-sm px-2 py-0.5 rounded font-mono" style="background-color: var(--color-code-bg); color: var(--color-accent);">mx pull &lt;name&gt;</code>
    </p>

    <div class="grid gap-3">
      {registry.map((pkg) => {
        const colors = ecosystemColors[pkg.ecosystem] || { bg: 'transparent', text: 'var(--color-text-tertiary)', border: 'var(--color-border)' };
        return (
          <a
            href={pkg.homepage}
            target="_blank"
            rel="noopener"
            class="flex items-center justify-between rounded-lg px-5 py-4 transition-colors group border"
            style={`background-color: var(--color-background-secondary); border-color: var(--color-border);`}
          >
            <div class="flex items-center gap-4">
              <div>
                <div class="flex items-center gap-3">
                  <span class="font-medium" style="color: var(--color-text);">{pkg.name}</span>
                  <span class="text-xs font-mono" style="color: var(--color-text-tertiary);">v{pkg.version}</span>
                  <span
                    class="text-xs px-2 py-0.5 rounded-full border font-mono"
                    style={`background-color: ${colors.bg}; color: ${colors.text}; border-color: ${colors.border};`}
                  >
                    {pkg.ecosystem}
                  </span>
                </div>
                <p class="text-sm mt-1" style="color: var(--color-text-tertiary);">{pkg.description}</p>
              </div>
            </div>
            <div class="flex items-center gap-6 text-xs font-mono shrink-0 ml-4" style="color: var(--color-text-tertiary);">
              <span>{pkg.entries} entries</span>
              <span>{pkg.size}</span>
            </div>
          </a>
        );
      })}
    </div>

    <div class="mt-12 rounded-lg p-6 text-center border" style="background-color: var(--color-background-secondary); border-color: var(--color-border);">
      <p class="text-sm" style="color: var(--color-text-secondary);">
        Want your library listed here?
        <a href="https://github.com/bhavnicksm/mandex" class="underline underline-offset-2" style="color: var(--color-accent);" target="_blank" rel="noopener">
          Open an issue on GitHub.
        </a>
      </p>
    </div>
  </section>
</Layout>
