---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Registry - mandex" description="Browse available documentation packages.">
<style>
  .package-item:hover {
    background-color: var(--color-background) !important;
  }
  #package-scroll::-webkit-scrollbar { width: 4px; }
  #package-scroll::-webkit-scrollbar-track { background: transparent; }
  #package-scroll::-webkit-scrollbar-thumb { background-color: var(--color-border); border-radius: 2px; }
</style>
  <section class="max-w-5xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold mb-2" style="color: var(--color-text);">Registry</h1>
    <p class="mb-6" style="color: var(--color-text-secondary);">
      Available documentation packages. Install with
      <code class="text-sm px-2 py-0.5 rounded font-mono" style="background-color: var(--color-code-bg); color: var(--color-accent);">mx pull &lt;name&gt;</code>
    </p>

    <!-- Search bar -->
    <div class="mb-8">
      <input
        id="package-search"
        type="text"
        placeholder="Search packages..."
        class="w-full px-4 py-2.5 rounded-lg border text-sm outline-none transition-colors"
        style="background-color: var(--color-background-secondary); border-color: var(--color-border); color: var(--color-text);"
      />
    </div>

    <!-- Scrollable package box -->
    <div id="package-box" class="rounded-xl border overflow-hidden" style="border-color: var(--color-border);">
      <!-- Loading state -->
      <div id="loading" class="text-center py-8 text-sm" style="color: var(--color-text-tertiary);">
        Loading packages...
      </div>

      <!-- Scrollable list -->
      <div id="package-scroll" class="overflow-y-auto" style="max-height: 480px; display: none;">
        <div id="package-list" class="grid gap-0 divide-y" style="border-color: var(--color-border);"></div>
        <!-- Sentinel for infinite scroll -->
        <div id="scroll-sentinel" class="h-1"></div>
      </div>

      <div id="no-results" class="hidden py-8 text-center text-sm" style="color: var(--color-text-tertiary);">
        No packages match your search.
      </div>
    </div>

    <div class="mt-6 rounded-lg p-5 text-center border" style="background-color: var(--color-background-secondary); border-color: var(--color-border);">
      <p class="text-sm" style="color: var(--color-text-secondary);">
        Want your library listed here?
        <a href="https://github.com/bhavnicksm/mandex" class="underline underline-offset-2" style="color: var(--color-accent);" target="_blank" rel="noopener">
          Open an issue on GitHub.
        </a>
      </p>
    </div>
  </section>
</Layout>

<script>
  const ecosystemColors: Record<string, { bg: string; text: string; border: string }> = {
    npm: { bg: 'rgba(239, 68, 68, 0.1)', text: '#ef4444', border: 'rgba(239, 68, 68, 0.2)' },
    pip: { bg: 'rgba(59, 130, 246, 0.1)', text: '#3b82f6', border: 'rgba(59, 130, 246, 0.2)' },
    cargo: { bg: 'rgba(249, 115, 22, 0.1)', text: '#f97316', border: 'rgba(249, 115, 22, 0.2)' },
    go: { bg: 'rgba(6, 182, 212, 0.1)', text: '#06b6d4', border: 'rgba(6, 182, 212, 0.2)' },
  };

  interface Package {
    name: string;
    description: string;
    ecosystem: string;
    latest_version: string;
    entry_count: number;
    size_bytes: number;
  }

  function formatSize(bytes: number): string {
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1048576) return `${(bytes / 1024).toFixed(1)} KB`;
    return `${(bytes / 1048576).toFixed(1)} MB`;
  }

  function renderPackage(pkg: Package): HTMLElement {
    const colors = ecosystemColors[pkg.ecosystem] || {
      bg: 'transparent',
      text: 'var(--color-text-tertiary)',
      border: 'var(--color-border)',
    };

    const a = document.createElement('a');
    a.href = `/packages/${pkg.name}`;
    a.className = 'package-item flex items-center justify-between px-5 py-4 transition-colors';
    a.style.cssText = 'background-color: var(--color-background-secondary); border-bottom: 1px solid var(--color-border); text-decoration: none;';
    // Use dataset/setAttribute so description/name can't break out of attribute context
    a.dataset.name = pkg.name;
    a.dataset.description = pkg.description;
    a.dataset.ecosystem = pkg.ecosystem;

    a.innerHTML = `
      <div>
        <div class="flex items-center gap-3">
          <span class="font-medium" style="color: var(--color-text);"></span>
          <span class="text-xs font-mono" style="color: var(--color-text-tertiary);">v${pkg.latest_version}</span>
          <span class="text-xs px-2 py-0.5 rounded-full border font-mono"
                style="background-color: ${colors.bg}; color: ${colors.text}; border-color: ${colors.border};">
            ${pkg.ecosystem}
          </span>
        </div>
        <p class="text-sm mt-1" style="color: var(--color-text-tertiary);"></p>
      </div>
      <div class="flex items-center gap-6 text-xs font-mono shrink-0 ml-4" style="color: var(--color-text-tertiary);">
        <span>${pkg.entry_count} entries</span>
        <span>${formatSize(pkg.size_bytes)}</span>
      </div>
    `;
    // Set text content via DOM to avoid injection
    a.querySelector<HTMLElement>('.font-medium')!.textContent = pkg.name;
    a.querySelector<HTMLElement>('.text-sm.mt-1')!.textContent = pkg.description;

    return a;
  }

  const listEl = document.getElementById('package-list')!;
  const loadingEl = document.getElementById('loading')!;
  const scrollEl = document.getElementById('package-scroll')!;
  const noResultsEl = document.getElementById('no-results')!;
  const sentinelEl = document.getElementById('scroll-sentinel')!;
  const searchEl = document.getElementById('package-search') as HTMLInputElement;

  const PAGE_SIZE = 10;
  let allPackages: Package[] = [];
  let filteredPackages: Package[] = [];
  let renderedCount = 0;
  let observer: IntersectionObserver | null = null;

  function renderNextPage() {
    const batch = filteredPackages.slice(renderedCount, renderedCount + PAGE_SIZE);
    batch.forEach(pkg => listEl.appendChild(renderPackage(pkg)));
    renderedCount += batch.length;

    // Disconnect observer if all rendered
    if (renderedCount >= filteredPackages.length && observer) {
      observer.disconnect();
    }
  }

  function setupObserver() {
    observer?.disconnect();
    observer = new IntersectionObserver(
      (entries) => { if (entries[0].isIntersecting) renderNextPage(); },
      { root: scrollEl, threshold: 0.1 }
    );
    observer.observe(sentinelEl);
  }

  function applyFilter(q: string) {
    const query = q.toLowerCase().trim();
    filteredPackages = query
      ? allPackages.filter(pkg =>
          pkg.name.toLowerCase().includes(query) ||
          pkg.description.toLowerCase().includes(query) ||
          pkg.ecosystem.toLowerCase().includes(query)
        )
      : allPackages;

    listEl.innerHTML = '';
    renderedCount = 0;
    renderNextPage();
    setupObserver();

    noResultsEl.classList.toggle('hidden', filteredPackages.length > 0);
  }

  async function loadPackages() {
    try {
      const res = await fetch('https://api.mandex.dev/packages');
      if (!res.ok) throw new Error('failed');
      allPackages = await res.json();
      filteredPackages = allPackages;

      loadingEl.style.display = 'none';
      scrollEl.style.display = 'block';

      renderNextPage();
      setupObserver();

      searchEl?.addEventListener('input', () => applyFilter(searchEl.value));
    } catch {
      loadingEl.textContent = 'Failed to load packages. Try refreshing.';
    }
  }

  loadPackages();
</script>
