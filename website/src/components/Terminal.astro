---
---

<div id="terminal-wrapper" class="terminal-window cursor-pointer relative group">
  <!-- Title bar -->
  <div class="terminal-titlebar">
    <div class="terminal-dots">
      <span class="terminal-dot terminal-dot-close"></span>
      <span class="terminal-dot terminal-dot-minimize"></span>
      <span class="terminal-dot terminal-dot-expand"></span>
    </div>
    <span class="terminal-title">mandex</span>
    <span id="copy-hint" class="terminal-copy-hint">
      click to copy install command
    </span>
  </div>
  <!-- Terminal body -->
  <div id="terminal" class="terminal-body">
    <div id="terminal-lines"></div>
    <div id="cursor-line" class="flex">
      <span class="terminal-prompt">$</span>&nbsp;<span id="typing-target"></span><span id="cursor" class="cursor-blink">&#9608;</span>
    </div>
  </div>
</div>

<style is:global>
  /* Terminal window */
  .terminal-window {
    border-radius: 10px;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.08),
      0 8px 40px rgba(0, 0, 0, 0.08),
      0 2px 8px rgba(0, 0, 0, 0.04);
    transition: box-shadow 0.3s ease;
  }
  .terminal-window:hover {
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.1),
      0 12px 48px rgba(0, 0, 0, 0.12),
      0 4px 12px rgba(0, 0, 0, 0.06);
  }

  /* Title bar — always the same gray chrome */
  .terminal-titlebar {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    background: #f0f0f0;
    border-bottom: 1px solid #d9d9d9;
    position: relative;
  }

  /* Traffic light dots */
  .terminal-dots {
    display: flex;
    gap: 8px;
  }
  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    position: relative;
  }
  .terminal-dot-close {
    background: #ff5f57;
    border: 1px solid #e0443e;
  }
  .terminal-dot-minimize {
    background: #febc2e;
    border: 1px solid #dea123;
  }
  .terminal-dot-expand {
    background: #28c840;
    border: 1px solid #1dad2b;
  }

  /* Title text */
  .terminal-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-size: 13px;
    font-family: 'Inter', -apple-system, sans-serif;
    color: #9F9D96;
    user-select: none;
  }

  /* Copy hint */
  .terminal-copy-hint {
    margin-left: auto;
    font-size: 11px;
    font-family: 'Inter', -apple-system, sans-serif;
    color: #B7B5AC;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .terminal-window:hover .terminal-copy-hint {
    opacity: 1;
  }

  /* Terminal body — default: dark terminal (for light page) */
  .terminal-body {
    background: #100F0F;
    padding: 20px 24px;
    font-family: 'JetBrains Mono', 'SF Mono', 'Menlo', 'Monaco', 'Consolas', monospace;
    font-size: 13.5px;
    line-height: 1.7;
    height: 360px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    color: #DAD8CE;
    box-shadow: inset 0 1px 4px rgba(0, 0, 0, 0.4);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Prompt — green on dark */
  .terminal-prompt {
    color: #34d399;
  }

  /* Cursor */
  .cursor-blink {
    animation: blink 1s step-end infinite;
    font-weight: normal;
    color: #34d399;
    opacity: 0.8;
  }
  @keyframes blink {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 0; }
  }

  /* Flexoki light terminal (for dark page) — via system preference */
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .terminal-body { background: #FFFCF0; box-shadow: inset 0 1px 4px rgba(0, 0, 0, 0.06); color: #282726; }
    :root:not([data-theme="light"]) .terminal-prompt { color: #879A39; }
    :root:not([data-theme="light"]) .cursor-blink { color: #282726; }
  }

  /* Flexoki light terminal (for dark page) — via manual toggle */
  [data-theme="dark"] .terminal-body { background: #FFFCF0; box-shadow: inset 0 1px 4px rgba(0, 0, 0, 0.06); color: #282726; }
  [data-theme="dark"] .terminal-prompt { color: #879A39; }
  [data-theme="dark"] .cursor-blink { color: #282726; }
</style>

<script>
  const linesContainer = document.getElementById('terminal-lines')!;
  const typingTarget = document.getElementById('typing-target')!;
  const cursorLine = document.getElementById('cursor-line')!;
  const copyHint = document.getElementById('copy-hint')!;

  let cancelToken = { cancelled: false };

  function getIsDark(): boolean {
    const theme = document.documentElement.getAttribute('data-theme');
    if (theme === 'dark') return true;
    if (theme === 'light') return false;
    return window.matchMedia('(prefers-color-scheme: dark)').matches;
  }

  function getColors() {
    const dark = getIsDark();
    // Flipped: light page = dark terminal, dark page = light terminal
    return {
      accent: dark ? '#879A39' : '#34d399',
      text: dark ? '#100F0F' : '#DAD8CE',
      secondary: dark ? '#575653' : '#878580',
    };
  }

  function buildSequence() {
    const c = getColors();
    return [
      { type: 'command', text: 'curl -fsSL https://mandex.dev/install.sh | sh' },
      { type: 'output', text: 'Installing mandex (mx)...', color: c.secondary },
      { type: 'output', text: '✓ Installed mx to /usr/local/bin/mx', color: c.accent },
      { type: 'blank' },
      { type: 'pause', delay: 600 },
      { type: 'command', text: 'mx pull pytorch@2.3.0' },
      { type: 'output', text: '↓ pytorch@2.3.0  3.8 MB  [===========] done', color: c.secondary },
      { type: 'output', text: 'Installed to ~/.mandex/cache/pytorch/2.3.0.db', color: c.secondary },
      { type: 'blank' },
      { type: 'pause', delay: 600 },
      { type: 'command', text: 'mx search pytorch "attention mechanism"' },
      { type: 'output', text: `<accent>pytorch@2.3.0</accent> — MultiheadAttention`, color: c.secondary },
      { type: 'output', text: 'Allows the model to jointly attend to information', color: c.secondary },
      { type: 'output', text: 'from different representation subspaces...', color: c.secondary },
      { type: 'output', text: '', color: c.secondary },
      { type: 'output', text: `<accent>pytorch@2.3.0</accent> — ScaledDotProductAttention`, color: c.secondary },
      { type: 'output', text: 'Computes scaled dot-product attention on query,', color: c.secondary },
      { type: 'output', text: 'key, and value tensors...', color: c.secondary },
      { type: 'blank' },
      { type: 'pause', delay: 800 },
      { type: 'command', text: 'mx sync' },
      { type: 'output', text: 'Reading requirements.txt...', color: c.secondary },
      { type: 'output', text: 'Resolved 8 dependencies to mandex packages', color: c.secondary },
      { type: 'output', text: '✓ All packages up to date', color: c.accent },
    ];
  }

  function sleep(ms: number, token: { cancelled: boolean }): Promise<void> {
    return new Promise((resolve, reject) => {
      setTimeout(() => {
        if (token.cancelled) reject('cancelled');
        else resolve();
      }, ms);
    });
  }

  function addOutputLine(text: string, color: string): void {
    const c = getColors();
    const line = document.createElement('div');
    const processed = text.replace(/<accent>(.*?)<\/accent>/g, `<span style="color:${c.accent}">$1</span>`);
    line.innerHTML = processed;
    line.style.color = color;
    line.style.paddingLeft = '1.1em';
    linesContainer.appendChild(line);
  }

  function addBlankLine(): void {
    const line = document.createElement('div');
    line.innerHTML = '&nbsp;';
    linesContainer.appendChild(line);
  }

  function commitCommandLine(text: string): void {
    const c = getColors();
    const line = document.createElement('div');
    line.innerHTML = `<span style="color:${c.accent}">$</span> <span style="color:${c.text}">${text}</span>`;
    linesContainer.appendChild(line);
  }

  async function typeText(text: string, token: { cancelled: boolean }): Promise<void> {
    typingTarget.textContent = '';
    for (let i = 0; i < text.length; i++) {
      if (token.cancelled) throw 'cancelled';
      typingTarget.textContent = text.slice(0, i + 1);
      await sleep(25 + Math.random() * 35, token);
    }
  }

  async function runSequence(token: { cancelled: boolean }): Promise<void> {
    const sequence = buildSequence();
    for (const step of sequence) {
      if (token.cancelled) return;
      if (step.type === 'command') {
        cursorLine.style.display = 'flex';
        await typeText(step.text!, token);
        await sleep(300, token);
        cursorLine.style.display = 'none';
        commitCommandLine(step.text!);
        typingTarget.textContent = '';
        await sleep(150, token);
      } else if (step.type === 'output') {
        addOutputLine(step.text!, step.color || getColors().secondary);
        await sleep(60, token);
      } else if (step.type === 'blank') {
        addBlankLine();
      } else if (step.type === 'pause') {
        cursorLine.style.display = 'flex';
        typingTarget.textContent = '';
        await sleep(step.delay || 500, token);
      }
    }
    cursorLine.style.display = 'flex';
    typingTarget.textContent = '';

    await sleep(4000, token);
    linesContainer.innerHTML = '';
    await sleep(500, token);
    if (!token.cancelled) runSequence(token);
  }

  function startTerminal() {
    cancelToken.cancelled = true;
    cancelToken = { cancelled: false };
    linesContainer.innerHTML = '';
    typingTarget.textContent = '';
    cursorLine.style.display = 'flex';
    runSequence(cancelToken).catch(() => {});
  }

  // Click to copy install command
  document.getElementById('terminal-wrapper')?.addEventListener('click', () => {
    navigator.clipboard.writeText('curl -fsSL https://mandex.dev/install.sh | sh');
    const original = copyHint.textContent;
    copyHint.textContent = 'copied!';
    copyHint.style.opacity = '1';
    setTimeout(() => {
      copyHint.textContent = original;
      copyHint.style.opacity = '';
    }, 1500);
  });

  // Restart on theme change
  window.addEventListener('theme-changed', () => startTerminal());

  startTerminal();
</script>
