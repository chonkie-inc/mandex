---

<div class="relative overflow-hidden h-full">
  <!-- Gradient fades -->
  <div class="absolute inset-x-0 top-0 h-12 z-10 pointer-events-none" style="background: linear-gradient(to bottom, var(--color-background), transparent);"></div>
  <div class="absolute inset-x-0 bottom-0 h-12 z-10 pointer-events-none" style="background: linear-gradient(to top, var(--color-background), transparent);"></div>

  <!-- Feed -->
  <div
    id="terminal-feed"
    class="h-full font-mono text-[15px] leading-[1.8] px-4 pt-6 overflow-hidden"
  >
    <div id="feed-content"></div>
  </div>
</div>

<script is:inline define:vars={{ feedItems }}>
  (function() {
    var container = document.getElementById('feed-content');
    if (!container) return;

    var CHAR_DELAY = 18;
    var LINE_DELAY = 35;
    var COMMAND_PAUSE = 600;
    var currentItem = 0;

    function createLine(html, style) {
      var div = document.createElement('div');
      div.innerHTML = html;
      if (style) {
        for (var k in style) div.style[k] = style[k];
      }
      return div;
    }

    function typeCommand(text, el) {
      return new Promise(function(resolve) {
        var i = 0;
        var cursor = document.createElement('span');
        cursor.className = 'cursor-blink';
        cursor.textContent = '▌';
        cursor.style.opacity = '0.35';
        el.appendChild(cursor);

        function next() {
          if (i < text.length) {
            cursor.before(document.createTextNode(text[i]));
            i++;
            setTimeout(next, CHAR_DELAY + Math.random() * 10);
          } else {
            cursor.remove();
            resolve();
          }
        }
        next();
      });
    }

    function scrollToBottom() {
      var feed = document.getElementById('terminal-feed');
      if (feed) feed.scrollTop = feed.scrollHeight;
    }

    function styleLine(text, type) {
      var s = {};
      var html = text;

      if (type === 'divider') {
        s.opacity = '0.15';
        s.color = 'var(--color-text)';
      } else if (type === 'heading') {
        s.color = 'var(--color-text)';
        s.opacity = '0.7';
        s.fontWeight = '600';
      } else if (type === 'markdown') {
        s.color = 'var(--color-text)';
        s.opacity = '0.6';
        s.fontWeight = '600';
      } else if (type === 'code') {
        s.color = 'var(--color-text)';
        s.opacity = '0.55';
        s.paddingLeft = '8px';
      } else if (type === 'prose') {
        s.color = 'var(--color-text)';
        s.opacity = '0.45';
      } else if (type === 'success') {
        html = text.replace(/✓/g, '<span style="opacity:0.8">✓</span>')
                   .replace(/\(([^)]+)\)/g, '<span style="opacity:0.5">($1)</span>');
        s.color = 'var(--color-text)';
        s.opacity = '0.65';
      } else if (type === 'info') {
        s.color = 'var(--color-text)';
        s.opacity = '0.35';
      } else if (type === 'blank') {
        html = '&nbsp;';
        s.lineHeight = '0.6';
      }

      return { html: html, style: s };
    }

    async function renderItem(item) {
      // Command line
      var cmdLine = createLine('');
      var prompt = document.createElement('span');
      prompt.style.color = 'var(--color-text)';
      prompt.style.opacity = '0.35';
      prompt.textContent = '$ ';
      cmdLine.appendChild(prompt);

      var cmdSpan = document.createElement('span');
      cmdSpan.style.color = 'var(--color-text)';
      cmdSpan.style.fontWeight = '500';
      cmdLine.appendChild(cmdSpan);

      container.appendChild(cmdLine);
      scrollToBottom();

      await typeCommand(item.command, cmdSpan);

      // Update preview panel if this is a search command
      if (item.preview) {
        window.dispatchEvent(new CustomEvent('doc-preview', { detail: item.preview }));
      } else {
        window.dispatchEvent(new CustomEvent('doc-preview', { detail: '' }));
      }

      await new Promise(function(r) { setTimeout(r, LINE_DELAY * 3); });

      // Output lines
      for (var i = 0; i < item.output.length; i++) {
        var line = item.output[i];
        var result = styleLine(line.text, line.type);
        var outLine = createLine(result.html, result.style);

        if (line.type !== 'blank' && line.type !== 'divider') {
          outLine.style.transform = 'translateY(3px)';
          outLine.style.transition = 'all 0.12s ease-out';
          var origOpacity = outLine.style.opacity;
          outLine.style.opacity = '0';
          container.appendChild(outLine);
          scrollToBottom();

          requestAnimationFrame(function(el, op) {
            return function() {
              el.style.opacity = op;
              el.style.transform = 'translateY(0)';
            };
          }(outLine, origOpacity));
        } else {
          container.appendChild(outLine);
          scrollToBottom();
        }

        await new Promise(function(r) { setTimeout(r, LINE_DELAY); });
      }

      // Blank line between commands
      container.appendChild(createLine('&nbsp;'));
      scrollToBottom();
    }

    async function runFeed() {
      while (true) {
        await renderItem(feedItems[currentItem]);
        currentItem = (currentItem + 1) % feedItems.length;
        await new Promise(function(r) { setTimeout(r, COMMAND_PAUSE); });

        while (container.children.length > 80) {
          container.removeChild(container.firstChild);
        }
      }
    }

    document.addEventListener('DOMContentLoaded', function() {
      runFeed();
    });
  })();
</script>
